# solver setup

solver_mode 		= adaptive_rom
rom_method  		= galerkin
pod_energy  		= 99.999
hyper	    		= true
hyper_method		= qdeim
init_training_win 	= 10

# time discretization
dt            = 5e-5
num_steps     = 3000
time_scheme   = explicit_fd_euler
dual_time     = false
res_tol       = 1e-5

# space discretization
x_initial   = 0
x_final     = 1
cell_number = 500 

# inlet BC
rho_inlet        = extrap
vel_inlet        = extrap
press_inlet      = extrap
temp_inlet       = extrap
mass_frac_inlet  = extrap

# outlet BC
rho_outlet        = extrap
vel_outlet        = extrap
press_outlet      = extrap
temp_outlet       = extrap
mass_frac_outlet  = extrap

# Initial Condition

x_interval_ic = [[0,0.5],[0.5,1]]
press_ic      = [1,0.1]
temp_ic       = [300,300]
vel_ic        = [0.001,0.001]
rho_ic        = [1,0.125]
mass_frac_ic  = [[1.0, 0.0],[1.0, 0.0]]

# gas model
gas_model   = ideal gas model
flux_scheme = roe

# Visualization

variable1 	= Density
variable2 	= Pressure
variable3 	= Velocity
variable4 	= None
update_interval = 100



