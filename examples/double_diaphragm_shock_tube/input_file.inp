# solver setup

solver_mode 		    = FOM
rom_method  		    = Galerkin
arom_method		        = Direct Adapt
pod_energy  		    = 99.999
hyper	    		    = True
hyper_method		    = QDEIM
init_training_win 	    = 10
unsampled_update_freq 	= 10
fom_results_dir		    = ""

# time discretization
dt            = 5e-5
num_steps     = 4000
time_scheme   = Explicit - FD Euler

# space discretization
x_initial   = 0
x_final     = 1
cell_number = 500 

# inlet BC
rho_inlet        = extrapolate
vel_inlet        = extrapolate
press_inlet      = extrapolate
temp_inlet       = extrapolate
mass_frac_inlet  = extrapolate

# outlet BC
rho_outlet        = extrapolate
vel_outlet        = extrapolate
press_outlet      = extrapolate
temp_outlet       = extrapolate
mass_frac_outlet  = extrapolate

# Initial Condition

x_interval_ic = [[0,0.3],[0.3,0.6],[0.6,1]]
press_ic      = [10,5,0.714]
temp_ic       = [300,300,300]
vel_ic        = [0.1,0.1,0.1]
rho_ic        = [15,7,1]
mass_frac_ic  = [[1.0, 0.0],[1.0, 0.0],[1.0,0.0]]

# gas model
gas_model   = Non-Reacting Air
flux_scheme = 2nd Order Roe
limiter	    = True
limiter_method  = barth
viscous	    = False

# Visualization

visual      = True
variable1 	= Density
variable2 	= Pressure
variable3 	= Velocity
variable4 	= None
update_interval = 100
plot_fom	    = False


# Profiling

profiling	= False


