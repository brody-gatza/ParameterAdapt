# solver
solver_mode   = ROM

# time discretization
dt            = 1e-9
num_steps     = 200000
time_scheme   = FDF

# space discretization
x_initial   = 0
x_final     = 0.0288
cell_number = 200

# inlet BC
rho_inlet         = periodic
vel_inlet         = periodic
press_inlet       = periodic
temp_inlet        = periodic
mass_frac_inlet   = periodic

# outlet BC
rho_outlet        = periodic
vel_outlet        = periodic
press_outlet      = periodic
temp_outlet       = periodic
mass_frac_outlet  = periodic


# Initial Condition
ic_path        = examples/1D_RDE/IC_ramp_PR_2_200.npy


# gas model
gas_model       = h2o2.yaml
flux_scheme     = 2nd Order Roe
limiter	        = False
limiter_method  = minmod    
viscous	        = False
numpy_vector    = True

# Visualization
visual          = True
save_visual     = False
variable1 	    = Heat Release
variable2 	    = Pressure
variable3 	    = MF
variable4 	    = Temprature
update_interval = 100

# Saving
save_interval   = 100

# Profiling
profiling	    = False

# Injection
injection                 = True
injection_state_dir       = examples/1D_RDE/Injection_Files/h2o2ar_phi_1_200ms_4atm_inject_prim_state.npy
rde                       = True
injector_face_area        = 0.5
injector_area_ratio       = 0.8
non_injection_portion     = 0.5
non_injection_tail_portion= 0.3

# ROM Setup
rom_method  		    = Galerkin
nl_rom_model            = rbf
arom_method		        = direct
pod_energy  		    = 99
hyper	    		    = True
hyper_method		    = QDEIM
sampling_rate           = 10
init_training_win 	    = 10
unsampled_update_freq 	= 10

training_data_dir       = exmaples/1D_RDE/FOM_results_11cycles
training_start_iter     = 50000
training_step_iter      = 10
training_end_iter       = 100000

rom_basis_generate       = False
rom_basis_dir            = examples/sod_shock_tube/precomputed_basis

sarom_training_step      = 100
sarom_srom_solver        = PROM
sarom_cumsum_tol         = 0.01
sarom_moving_avg_tol     = 0.01

# Restart 
arom_restart            = False





