# solver setup

solver_mode 		    = FOM
rom_method  		    = Galerkin
arom_method		        = Direct Adapt
pod_energy  		    = 99.99999
hyper	    		    = True
hyper_method		    = QDEIM
init_training_win 	    = 10
unsampled_update_freq 	= 10
fom_results_dir		    = ""
fom_results_max_iter    = ""


fom_results_start     = 12560
fom_results_end       = 25120
fom_results_step      = 100

# time discretization
dt            = 2e-6
num_steps     = 5000
time_scheme   = Explicit - FD Euler

# space discretization
x_initial   = 0
x_final     = 1
cell_number = 500 

# inlet BC
rho_inlet        = 1.225/0.1225/5000
vel_inlet        = extrapolate
press_inlet      = extrapolate
temp_inlet       = extrapolate
mass_frac_inlet  = extrapolate

# outlet BC
rho_outlet        = extrapolate
vel_outlet        = extrapolate
press_outlet      = extrapolate
temp_outlet       = extrapolate
mass_frac_outlet  = extrapolate

# Initial Condition

# ic_path = ""

x_interval_ic = [[0,1]]
rho_ic        = [1.225]
vel_ic        = [500]
press_ic      = [101325]
temp_ic       = [300]
mass_frac_ic  = [[1.0, 0.0]]


# gas model
gas_model       = Non-Reacting Air
flux_scheme     = 1st Order Roe
limiter	        = False
limiter_method  = minmod
viscous	        = False

# Visualization

visual          = True
variable1 	    = Density
variable2 	    = Pressure
variable3 	    = Velocity
variable4 	    = Temprature
update_interval = 1000
plot_fom	    = False

# Saving
save_interval   = 1

# Profiling
profiling	    = True






