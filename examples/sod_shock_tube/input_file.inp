# solver
solver_mode   = AROM

# time discretization
dt            = 5e-5
num_steps     = 5000
time_scheme   = FDF

# space discretization
x_initial   = 0
x_final     = 1
cell_number = 500

# inlet BC
rho_inlet        = extrapolate
vel_inlet        = extrapolate
press_inlet      = extrapolate
temp_inlet       = extrapolate
mass_frac_inlet  = extrapolate

# outlet BC
rho_outlet        = extrapolate
vel_outlet        = extrapolate
press_outlet      = extrapolate
temp_outlet       = extrapolate
mass_frac_outlet  = extrapolate

# Initial Condition

# ic_path = ""

x_interval_ic = [[0,0.5],[0.5,1]]
rho_ic        = [1,0.125]
vel_ic        = [0.001,0.001]
press_ic      = [1,0.1]
temp_ic       = [300,300]
mass_frac_ic  = [[1.0, 0.0],[1.0, 0.0]]


# gas model
gas_model       = Air
flux_scheme     = 2nd Order Roe
limiter	        = False
limiter_method  = minmod
viscous	        = False

# Visualization
visual          = True
save_visual     = False
variable1 	    = Density
variable2 	    = Pressure
variable3 	    = Velocity
variable4 	    = Temprature
update_interval = 100

# Saving
save_interval   = 100

# Profiling
profiling	    = False

# Injection
injection       = False

# ROM Setup
rom_method  		    = Galerkin
nl_rom_model            = rbf
arom_method		        = direct
pod_energy  		    = 99.999
hyper	    		    = True
hyper_method		    = QDEIM
sampling_rate           = 2
init_training_win 	    = 10
unsampled_update_freq 	= 10

training_data_dir       = C:\GIT_Fork\ROMify\examples\sod_shock_tube\FOM_results
training_start_iter     = 0
training_step_iter      = 100
training_end_iter       = 3000

rom_basis_generate       = True
rom_basis_dir            = C:\GIT_Fork\ROMify\examples\sod_shock_tube\precomputed_basis

sarom_training_step      = 100
sarom_srom_solver        = PROM
sarom_cumsum_tol         = 0.01
sarom_moving_avg_tol     = 0.01

# Restart 
arom_restart            = False





